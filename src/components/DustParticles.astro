---
// 흩날리는 빛 먼지 — day_001.md "먼지 한 톨의 궤도까지" 구절에서 착안.
// CSS 애니메이션만 사용(무거운 캔버스/JS 파티클 라이브러리 지양), 개수 적게·움직임 느리게·
// opacity 낮게로 "아주 약하게" 요구를 만족시킨다. 위치·타이밍은 빌드타임에 결정론적으로
// 계산해(Math.random 미사용) 매 빌드 결과가 재현 가능하게 한다.
const COUNT = 14;

const particles = Array.from({ length: COUNT }, (_, i) => {
  const left = (i * 71) % 100;
  const top = (i * 47 + 13) % 100;
  const size = 2 + (i % 3);
  const duration = 20 + (i % 5) * 4;
  const delay = -((i * 2.7) % duration);
  const peakOpacity = (0.15 + (i % 4) * 0.05).toFixed(2);
  const driftX = (i % 2 === 0 ? 1 : -1) * (10 + (i % 5) * 2);
  const driftY = -(45 + (i % 6) * 9);
  return { left, top, size, duration, delay, peakOpacity, driftX, driftY };
});
---

<div class="dust-field" aria-hidden="true">
  {
    particles.map((p) => (
      <span
        style={`--x:${p.left}%; --y:${p.top}%; --size:${p.size}px; --dur:${p.duration}s; --delay:${p.delay}s; --peak:${p.peakOpacity}; --dx:${p.driftX}px; --dy:${p.driftY}px;`}
      />
    ))
  }
</div>
